<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.fragment.HomeFragment">

    <ImageView
        android:id="@+id/fondo_home"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="Fondo principal"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_home"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <!--
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_home"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:layout_marginTop="52dp"
        android:background="@drawable/toolbar_background"
        app:menu="@menu/toolbar_home_menu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
        -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/toolbar_home"
        android:layout_width="300dp"
        android:layout_height="56dp"
        android:layout_marginTop="42dp"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="40dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_calificar"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:src="@drawable/icono_calificar"
                android:contentDescription="Calificar aplicación"/>

            <ImageButton
                android:id="@+id/btn_volumen"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:src="@drawable/icono_volume_on"
                android:contentDescription="Activar o desactivar volumen"/>

            <ImageButton
                android:id="@+id/btn_instrucciones"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:src="@drawable/icono_instrucciones"
                android:contentDescription="Ver instrucciones"/>

            <ImageButton
                android:id="@+id/btn_retos"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:src="@drawable/icono_agregar_reto"
                android:contentDescription="Agregar reto"/>

            <ImageButton
                android:id="@+id/btn_compartir"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:src="@drawable/icono_compartir"
                android:contentDescription="Compartir aplicación"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/botella_juego"
        android:layout_width="461dp"
        android:layout_height="431dp"
        android:scaleType="fitCenter"
        android:src="@drawable/botella_juego"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_contador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/contador_home"
        android:textColor="@color/orange"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/botella_juego"
        app:layout_constraintBottom_toBottomOf="@id/botella_juego"
        app:layout_constraintStart_toStartOf="@id/botella_juego"
        app:layout_constraintEnd_toEndOf="@id/botella_juego"/>

    <ImageButton
        android:id="@+id/btn_girar_botella"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginBottom="56dp"
        android:background="@android:color/transparent"
        android:contentDescription="Presióname"
        android:src="@drawable/boton_home"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/texto_presioname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/boton_presioname"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btn_girar_botella"
        app:layout_constraintStart_toStartOf="@id/btn_girar_botella"
        app:layout_constraintEnd_toEndOf="@id/btn_girar_botella" />

</androidx.constraintlayout.widget.ConstraintLayout>